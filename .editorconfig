# EditorConfig is awesome: https://EditorConfig.org
# This file configures code formatting across different editors and IDEs

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Python files
[*.{py,pyw,pyi,pyx,pxd,pxi}]
indent_style = space
indent_size = 4
max_line_length = 88
quote_style = double

# Django templates and HTML
[*.{html,htm,xhtml,xml,jinja,jinja2,j2}]
indent_style = space
indent_size = 2
max_line_length = 88

# CSS, SCSS, and related
[*.{css,scss,sass,less,styl,stylus}]
indent_style = space
indent_size = 2
max_line_length = 88

# JavaScript, TypeScript, and Node.js files
[*.{js,jsx,ts,tsx,mjs,cjs}]
indent_style = space
indent_size = 2
max_line_length = 88
quote_style = single

# JSON and JSON-like formats
[*.{json,jsonc,json5}]
indent_style = space
indent_size = 2

# YAML and configuration files
[*.{yaml,yml}]
indent_style = space
indent_size = 2

# Markdown files
[*.{md,mdx,markdown}]
trim_trailing_whitespace = false
max_line_length = 88

# TOML and INI files
[*.{toml,ini,cfg}]
indent_style = space
indent_size = 4

# Shell scripts and batch files
[*.{sh,bash,zsh,fish,bat,cmd,ps1}]
indent_style = space
indent_size = 4
end_of_line = lf

# Docker and related
[{Dockerfile,dockerfile,docker-compose.*,*.dockerignore}]
indent_style = space
indent_size = 2

# Makefiles and shell-like
[Makefile]
indent_style = tab

# Requirements and dependencies
[{requirements*.txt,setup.py,setup.cfg,pyproject.toml,package.json,package-lock.json}]
indent_style = space
indent_size = 4

# Default configuration files
[default.conf]
indent_style = space
indent_size = 2

# Git-related files
[.git*]
indent_style = space
indent_size = 2

# GitHub Actions and CI/CD
[.github/**]
indent_style = space
indent_size = 2

# Editor configurations
[.editorconfig]
indent_style = space
indent_size = 2
