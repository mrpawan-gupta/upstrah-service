SECRET_KEY=change-me-to-a-random-string
DEBUG=True
DJANGO_SETTINGS_MODULE=rudra.settings.local

# JWT (RS256) — auto-generated in DEBUG=True; required in production.
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Paste PEM contents with literal \n for newlines.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Apple Sign In
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_TEAM_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI=

# Google Cloud Storage
GS_MEDIA_BUCKET_NAME=dummy
GS_STATIC_BUCKET_NAME=dummy
GS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Mailgun credentials (required when EMAIL_PRIMARY_PROVIDER=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
